default_platform(:ios)

platform :ios do
  private_lane :app_store_api_key do
    next nil unless ENV["APP_STORE_CONNECT_API_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"] && ENV["APP_STORE_CONNECT_API_KEY_PATH"]

    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
  end

  private_lane :app_store_version do
    ENV["APP_STORE_VERSION"] || get_version_number(
      xcodeproj: "OpenResponses.xcodeproj",
      target: "OpenResponses"
    )
  end

  desc "Upload App Store metadata without a binary"
  lane :metadata do
    api_key = app_store_api_key
    version = app_store_version

    deliver(
      api_key: api_key,
      app_version: version,
      skip_binary_upload: true,
      skip_screenshots: ENV["DELIVER_SCREENSHOTS"] != "1",
      force: true,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Build the app and upload the binary plus metadata to App Store Connect"
  lane :release do
    api_key = app_store_api_key
    version = app_store_version

    build_app(
      scheme: "OpenResponses",
      export_method: "app-store",
      output_directory: "build",
      output_name: "OpenResponses.ipa",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      app_version: version,
      ipa: lane_context[SharedValues::IPA_OUTPUT_PATH],
      skip_screenshots: ENV["DELIVER_SCREENSHOTS"] != "1",
      force: true,
      metadata_path: "fastlane/metadata",
      screenshots_path: "fastlane/screenshots",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end
end
